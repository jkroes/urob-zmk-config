#define SWAPPER_TAB &swapper_kp 0 TAB
ZMK_HOLD_TAP(swapper_kp, bindings = <&swapper>, <&kp>; TP_CORE)
TRI_STATE(swapper, &kt LCTRL &kp TAB &kt LCTRL, LN1 RM1 RM2 RM3 RM4)
#define WORD_LEFT  &kp LA(LEFT)
#define WORD_RIGHT &kp LA(RIGHT)
#define NAV_LEFT   &tp_kp LC(LEFT)  LEFT  // Tap: left | Long-tap: start of line
#define NAV_RIGHT  &tp_kp LC(RIGHT) RIGHT // Tap: right | Long-tap: end of line
#define NAV_UP     &tp_kp LC(UP)    UP    // Tap: up | Long-tap: start of doc
#define NAV_DOWN   &tp_kp LC(DOWN)  DOWN  // Tap: down | Long-tap: end of doc
// #define CANCEL     &kp K_CANCEL           // Cancel caps-word & auto-layers


#define SWAPPER_TAB_PC &swapper_pc_kp 0 TAB
ZMK_HOLD_TAP(swapper_pc_kp, bindings = <&swapper_pc>, <&kp>; TP_CORE)
TRI_STATE(swapper_pc, &kt LALT &kp TAB &kt LALT, LN1 RM1 RM2 RM3 RM4)
#define WORD_LEFT_PC  &kp LC(LEFT)
#define WORD_RIGHT_PC &kp LC(RIGHT)
#define NAV_LEFT_PC   &tp_kp HOME     LEFT  
#define NAV_RIGHT_PC  &tp_kp END      RIGHT 
#define NAV_UP_PC     &tp_kp LC(HOME) UP 
#define NAV_DOWN_PC   &tp_kp LC(END)  DOWN  


