//#define _REDO      &kp LS(LC(Z))          // MacOS or Google Workspace or VSCode
//#define _REDO2     &kp LC(Y)              // Windows or Microsoft Office
#define select_all kp LC(A)
MACRO(select_none, &kp DOWN &kp UP &kp RIGHT &kp LEFT, 1, 1)

#define NAV_BEHAVIORS(_W, _HOME, _END, suffix)                                            \
  SIMPLE_MORPH(select_word ## suffix, SFT, &select_word_right, &select_word_left)         \
  MACRO(select_word_right  ## suffix, &kp _W(RIGHT) &kp _W(LEFT) &kp _W(LS(RIGHT)), 1, 1) \
  MACRO(select_word_left   ## suffix,  &kp _W(LEFT) &kp _W(RIGHT) &kp _W(LS(LEFT)), 1, 1) \
                                                                                          \
  SIMPLE_MORPH(extend_word ## suffix, SFT, &extend_word_right, &extend_word_left)         \
  MACRO(extend_word_right  ## suffix, &kp _W(LS(RIGHT)), 1, 1)                            \
  MACRO(extend_word_left   ## suffix,  &kp _W(LS(LEFT)), 1, 1)                            \
                                                                                          \
  SIMPLE_MORPH(select_line ## suffix, SFT, &select_line_right, &select_line_left)         \
  MACRO(select_line_right  ## suffix, &kp _HOME &kp LS(_END), 1, 1)                       \
  MACRO(select_line_left   ## suffix,  &kp _END &kp LS(_HOME), 1, 1)                      \
                                                                                          \
  SIMPLE_MORPH(extend_line ## suffix, SFT, &extend_line_right, &extend_line_left)         \
  MACRO(extend_line_right  ## suffix, &kp LS(DOWN) &kp LS(_END), 1, 1)                    \
  MACRO(extend_line_left   ## suffix, &kp LS(UP) &kp LS(_HOME), 1, 1)

NAV_BEHAVIORS(LA, LC(LEFT), LC(RIGHT),)
NAV_BEHAVIORS(LC, HOME, END, _pc)

