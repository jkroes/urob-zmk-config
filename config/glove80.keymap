//ZMK_CONDITIONAL_LAYER(sys, SYM NUM, SYS) // FN + NUM --> SYS.
ZMK_CONDITIONAL_LAYER(nav_pc, PC NAV, NAV_PC) // FN + NUM --> SYS.

