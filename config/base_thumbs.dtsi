#include <behaviors/num_word.dtsi> // Requires auto-layer module.

// Tap: bspc | Hold: nav layer | Shift-hold: toggle nav layer
#define BSPC_NAV &bspc_nav NAV BSPC
ZMK_HOLD_TAP(bspc_nav, bindings = <&nav_morph>, <&kp>; 
             flavor = "balanced"; tapping-term-ms = <300>; 
             quick-tap-ms = <QUICK_TAP_MS>;)
SIMPLE_MORPH(nav_morph, SFT, &mo NAV, &tog NAV)

// Tap: ret | Hold: num layer | Shift-hold: num-word 
#define RET_NUM &ret_num 0 RET
ZMK_HOLD_TAP(ret_num, bindings = <&num_morph>, <&kp>; 
             flavor = "balanced"; tapping-term-ms = <300>; 
             quick-tap-ms = <QUICK_TAP_MS>;)
SIMPLE_MORPH(num_morph, SFT, &mo NUM, &num_word NUM)

// Tap: space
// Right shift-tap (after alpha): dot -> space -> sticky shift | 
// Hold: shift
// Shift-hold: caps-word 
#define MAGIC_SHIFT &magic_shift 0 0
ZMK_HOLD_TAP(magic_shift, bindings = <&shift_morph>, <&spc_morph>;
             flavor = "balanced"; tapping-term-ms = <300>;
             quick-tap-ms = <QUICK_TAP_MS>;)
SIMPLE_MORPH(shift_morph, SFT, &shift_layer, &caps_word)
ZMK_MACRO(shift_layer, bindings = <&mo TYPING &kp LSHFT>; wait-ms = <0>; tap-ms = <5>;)
ZMK_MOD_MORPH(spc_morph, bindings = <&kp SPACE>, <&dot_spc>;
              mods = <(MOD_RSFT)>;)
ZMK_MACRO(dot_spc, bindings = <&kp DOT &kp SPACE &sk LSHFT>; wait-ms = <0>; tap-ms = <5>;)
