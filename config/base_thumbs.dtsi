#include <behaviors/num_word.dtsi> // Requires auto-layer module.

#define SUPER_NAV &super_nav NAV 0
ZMK_HOLD_TAP(super_nav, bindings = <&mo>, <&bspc_morph>; 
             flavor = "balanced"; tapping-term-ms = <300>; 
             quick-tap-ms = <QUICK_TAP_MS>;)
ZMK_MOD_MORPH(bspc_morph, bindings = <&kp BSPC>, <&kp DEL>;
              mods = <(MOD_LSFT)>;)

#define SMART_NUM &smart_num 0 0
ZMK_HOLD_TAP(smart_num, bindings = <&num_morph>, <&ret_morph>; 
             flavor = "balanced"; tapping-term-ms = <300>; 
             quick-tap-ms = <QUICK_TAP_MS>;)
SIMPLE_MORPH(num_morph, SFT, &mo NUM, &num_word NUM)
ZMK_MOD_MORPH(ret_morph, bindings = <&kp RET>, <&kp ESC>;
              mods = <(MOD_RSFT)>;)

// Tap: space | Shift + tap: dot -> space -> sticky shift | 
// Hold: shift | Shift + hold: caps-word 
// TODO adaptive key to cancel dot_spc for non-alpha keys that
// follow dot_spc
// TODO Add back the mouse layer
#define MAGIC_SHIFT &magic_shift 0 0
ZMK_HOLD_TAP(magic_shift, bindings = <&shift_morph>, <&spc_morph>;
             flavor = "balanced"; tapping-term-ms = <300>;
             quick-tap-ms = <QUICK_TAP_MS>;)
SIMPLE_MORPH(shift_morph, SFT, &kp LSHFT, &caps_word)
ZMK_MOD_MORPH(spc_morph, bindings = <&kp SPACE>, <&dot_spc>;
              mods = <(MOD_RSFT)>;)
ZMK_MACRO(dot_spc, bindings = <&kp DOT &kp SPACE &sk LSHFT>; wait-ms = <0>;
          tap-ms = <5>;)
&caps_word { // Mods deactivate caps-word, requires PR #1451. [TODO: rebase]
  /delete-property/ ignore-modifiers;
};
